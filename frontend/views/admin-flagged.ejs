<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <title>Flagged Batches</title>
</head>
<body>
  <%- include('partials/navbar', { user: user, hideAuthLinks: false }) %>

  <div class="container mt-4">
    <h2>Flagged / Suspicious Drug Batches</h2>
    <p>This list shows all drugs that have been flagged as potentially counterfeit or unauthentic during verification.</p>

    <% if (flaggedDrugs && flaggedDrugs.length > 0) { %>
      <table class="table table-striped table-bordered table-hover mt-4">
        <thead class="table-dark">
          <tr>
            <th>Drug ID</th>
            <th>Name</th>
            <th>Manufacturer</th>
            <th>Current Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% flaggedDrugs.forEach(drug => { %>
            <tr>
              <td><%= drug.id %></td>
              <td><%= drug.name %></td>
              <%# Display the manufacturer address, truncate for readability %>
              <td>
                <span title="<%= drug.manufacturer %>">
                  <%= drug.manufacturer.substring(0, 10) %>...
                </span>
              </td>
              <td><%= drug.status %></td>
              <td>
                <%# Future actions can be added here %>
                <a href="#" class="btn btn-sm btn-info">View History</a>
                <a href="#" class="btn btn-sm btn-success">Unflag</a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } else { %>
      <div class="alert alert-success mt-4" role="alert">
        <strong>No flagged batches found.</strong> All drugs in the system appear to be authentic.
      </div>
    <% } %>
  </div>
</body>
</html>
